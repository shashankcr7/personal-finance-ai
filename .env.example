# Copy to .env and fill from each provider's dashboard. NEVER commit .env.
# --- Supabase (Project Settings > Database / API) ---
# Use the SESSION POOLER connection string (port 5432) for IPv4 hosts like Render.
DATABASE_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# --- Anthropic (console.anthropic.com) — backend only ---
ANTHROPIC_API_KEY=
# --- App ---
ALLOWED_EMAILS=you@example.com,spouse@example.com
# Origin allowed to call the API (CORS). The Next.js dev server by default.
FRONTEND_ORIGIN=http://localhost:3000
